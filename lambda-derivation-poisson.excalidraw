      ],
      "updated": 1772596919178,
      "link": null,
      "locked": false,
      "text": "It is monotonically equivalent to\nthe equation original equation.\nWhich means that the equation\nmoves in the same direction as the\noriginal. For whatever value is input\ninto the log likelihood the smallest\nvalue will still be the smallest for\nlog like with the original.",
      "fontSize": 29.372519841269835,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It is monotonically equivalent to the equation original equation. Which means that the equation moves in the same direction as the original. For whatever value is input into the log likelihood the smallest value will still be the smallest for log like with the original.",
      "autoResize": false,
      "lineHeight": 1.25
    },
